# ==============================================================================
# Fyers (NSE/India) - Required for NSE market data
# ==============================================================================
NANOEDGE_FYERS_APP_ID=your_app_id_here
NANOEDGE_FYERS_SECRET=your_secret_here
# Access token from OAuth2 flow (see nanoedge/connectors/fyers/auth.py)
NANOEDGE_FYERS_ACCESS_TOKEN=
# Redirect URI for OAuth2 callback
NANOEDGE_FYERS_REDIRECT_URI=http://localhost:8000/fyers/callback
# Fyers endpoints (defaults shown)
# NANOEDGE_FYERS_WS_URL=wss://api-t1.fyers.in/feed/data-ws
# NANOEDGE_FYERS_REST_URL=https://api-t1.fyers.in

# ==============================================================================
# Binance - Optional for public data, required for trading
# ==============================================================================
NANOEDGE_BINANCE_API_KEY=your_api_key_here
NANOEDGE_BINANCE_SECRET=your_secret_here
# Binance endpoints (defaults shown)
# NANOEDGE_BINANCE_WS_URL=wss://stream.binance.com:9443
# NANOEDGE_BINANCE_FUTURES_WS_URL=wss://fstream.binance.com
# NANOEDGE_BINANCE_COIN_WS_URL=wss://dstream.binance.com
# NANOEDGE_BINANCE_REST_URL=https://api.binance.com
# NANOEDGE_BINANCE_FUTURES_REST_URL=https://fapi.binance.com
# NANOEDGE_BINANCE_COIN_REST_URL=https://dapi.binance.com

# ==============================================================================
# QuestDB
# ==============================================================================
NANOEDGE_QUESTDB_HOST=localhost
NANOEDGE_QUESTDB_ILP_PORT=9009
NANOEDGE_QUESTDB_HTTP_PORT=9000

# ==============================================================================
# API Server
# ==============================================================================
NANOEDGE_API_HOST=0.0.0.0
NANOEDGE_API_PORT=8000

# ==============================================================================
# Symbol Settings
# ==============================================================================
# Default symbols to track (JSON array format, for backward compatibility)
# NANOEDGE_SYMBOLS=["BTCUSDT","ETHUSDT"]

# Symbol database path (SQLite for persistence)
# NANOEDGE_SYMBOL_DB_PATH=nanoedge/data/symbols.db

# Refresh symbols from exchanges on startup
NANOEDGE_SYMBOL_REFRESH_ON_STARTUP=true

# ==============================================================================
# Performance Settings
# ==============================================================================
# Ring buffer capacity (ticks per symbol)
NANOEDGE_RING_BUFFER_CAPACITY=1000000

# Max symbols to keep in LRU cache for quick switching
NANOEDGE_MAX_CACHED_SYMBOLS=5
