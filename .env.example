# ==============================================================================
# Fyers (NSE/India) - Required for NSE market data
# ==============================================================================
HFT_FYERS_APP_ID=your_app_id_here
HFT_FYERS_SECRET=your_secret_here
# Access token from OAuth2 flow (see hft/connectors/fyers/auth.py)
HFT_FYERS_ACCESS_TOKEN=
# Redirect URI for OAuth2 callback
HFT_FYERS_REDIRECT_URI=http://localhost:8000/fyers/callback
# Fyers endpoints (defaults shown)
# HFT_FYERS_WS_URL=wss://api-t1.fyers.in/feed/data-ws
# HFT_FYERS_REST_URL=https://api-t1.fyers.in

# ==============================================================================
# Binance - Optional for public data, required for trading
# ==============================================================================
HFT_BINANCE_API_KEY=your_api_key_here
HFT_BINANCE_SECRET=your_secret_here
# Binance endpoints (defaults shown)
# HFT_BINANCE_WS_URL=wss://stream.binance.com:9443
# HFT_BINANCE_FUTURES_WS_URL=wss://fstream.binance.com
# HFT_BINANCE_COIN_WS_URL=wss://dstream.binance.com
# HFT_BINANCE_REST_URL=https://api.binance.com
# HFT_BINANCE_FUTURES_REST_URL=https://fapi.binance.com
# HFT_BINANCE_COIN_REST_URL=https://dapi.binance.com

# ==============================================================================
# QuestDB
# ==============================================================================
HFT_QUESTDB_HOST=localhost
HFT_QUESTDB_ILP_PORT=9009
HFT_QUESTDB_HTTP_PORT=9000

# ==============================================================================
# API Server
# ==============================================================================
HFT_API_HOST=0.0.0.0
HFT_API_PORT=8000

# ==============================================================================
# Symbol Settings
# ==============================================================================
# Default symbols to track (JSON array format, for backward compatibility)
# HFT_SYMBOLS=["BTCUSDT","ETHUSDT"]

# Symbol database path (SQLite for persistence)
# HFT_SYMBOL_DB_PATH=hft/data/symbols.db

# Refresh symbols from exchanges on startup
HFT_SYMBOL_REFRESH_ON_STARTUP=true

# ==============================================================================
# Performance Settings
# ==============================================================================
# Ring buffer capacity (ticks per symbol)
HFT_RING_BUFFER_CAPACITY=1000000

# Max symbols to keep in LRU cache for quick switching
HFT_MAX_CACHED_SYMBOLS=5
